# Production environment template (Railway / Render / Fly / VPS)
# Copy values into your host's secret manager — do not commit real keys.

OPTIONS_DATA_DIR=/data
OPTIONS_PUBLIC_URL=https://your-production-domain.com
OPTIONS_COOKIE_SECURE=true

# LLM (at least one)
OPENAI_API_KEY=
#ANTHROPIC_API_KEY=
#GOOGLE_API_KEY=

# Optional
#AUTONOMOUS_ENABLED=true
#OPTIONS_CORS_ORIGINS=https://your-app.lovable.app,https://your-custom-domain.com

# TradingView legacy single-tenant fallback (optional if using per-user secrets)
#TRADINGVIEW_WEBHOOK_SECRET=
