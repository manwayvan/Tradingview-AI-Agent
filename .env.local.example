# Local overrides — copy to .env.local (gitignored)
# Loaded automatically by `make dev` and scripts/dev.sh

# Shown in TradingView setup wizard when using a tunnel:
# OPTIONS_PUBLIC_URL=https://your-subdomain.trycloudflare.com

# Dev server port (default 8000)
# PORT=8000

# Enable autonomous brain on dev server start
# AUTONOMOUS_ENABLED=true

# Local SQLite path (default ~/.tradingagents/app.db)
# OPTIONS_APP_DB=./.local/app.db
